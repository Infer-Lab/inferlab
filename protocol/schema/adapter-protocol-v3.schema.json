          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "primary_readiness": {
          "$ref": "#/$defs/ReadinessProbe"
        },
        "replica_index": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "role_id": {
          "type": "string"
        },
        "worker_readiness": {
          "$ref": "#/$defs/ReadinessProbe"
        }
