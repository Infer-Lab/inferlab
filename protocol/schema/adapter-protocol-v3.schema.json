              "type": "null"
            }
          ]
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ServeRoleLink"
          }
        },
        "model": {
          "$ref": "#/$defs/ServeModelInput"
        },
        "parallelism": {
          "$ref": "#/$defs/Parallelism"
        },
        "profiling": {
          "type": "boolean",
          "default": false
        },
        "roles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ServeRoleResult"
          }
        },
        "routing_backend": {
          "type": "string"
        },
        "settings": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/SettingValue"
          }
        },
        "topology": {
          "$ref": "#/$defs/ServeTopology"
        }
      },
      "additionalProperties": false,
      "required": [
        "model",
        "topology",
        "routing_backend",
        "parallelism",
        "settings",
        "roles",
        "links",
        "allocations"
      ]
