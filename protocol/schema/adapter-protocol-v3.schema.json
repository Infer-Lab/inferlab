        "machine_id": {
          "type": "string"
        },
        "model_locator": {
          "type": "string"
        },
        "ports": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/EndpointAssignment"
          }
        },
        "process_id": {
          "type": "string"
        },
        "rank": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "replica_id": {
          "type": "string"
        },
        "replica_index": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "role_id": {
          "type": "string"
        },
        "runtime_cache_root": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "process_id",
        "role_id",
        "replica_id",
        "replica_index",
        "rank",
        "machine_id",
        "model_locator",
        "runtime_cache_root",
        "devices",
        "endpoint",
        "ports"
      ]
