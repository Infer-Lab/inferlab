      "properties": {
        "integration": {
          "$ref": "#/$defs/IntegrationIdentity"
        },
        "processes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RenderedServeProcess"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "integration",
        "processes"
      ]
