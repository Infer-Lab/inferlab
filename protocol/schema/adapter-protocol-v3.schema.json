      "description": "One concrete process the control plane placed, supplied to `RenderServe`:\nits identity, rank, machine, devices, model locator, and allocated\nendpoints and named ports.",
      "type": "object",
      "properties": {
        "devices": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "uint32",
            "minimum": 0
          }
        },
        "endpoint": {
          "$ref": "#/$defs/EndpointAssignment"
