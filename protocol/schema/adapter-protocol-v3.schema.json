        {
          "description": "Aggregated serving role of a single topology.",
          "type": "string",
          "const": "serve"
        },
        {
          "description": "Prefill role of a disaggregated topology.",
          "type": "string",
          "const": "prefill"
        },
        {
          "description": "Decode role of a disaggregated topology.",
          "type": "string",
          "const": "decode"
        },
        {
          "description": "Request-routing role that does not execute model inference.",
          "type": "string",
          "const": "router"
        }
      ]
    },
    "ServeRoleLink": {
      "description": "A directed link between serve roles the integration declares as part of the\ntopology.",
      "oneOf": [
        {
          "description": "The source role routes requests to the target roles.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "request_routing"
            },
            "source": {
              "type": "string"
            },
            "targets": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "source",
            "targets"
          ]
        },
        {
          "description": "KV cache is transferred from source to target over `mechanism`.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "kv_transfer"
            },
            "mechanism": {
              "$ref": "#/$defs/KvTransferMechanism"
            },
            "source": {
              "type": "string"
            },
            "target": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "source",
            "target",
            "mechanism"
          ]
        },
        {
          "description": "The source discovers the target through a bootstrap port.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "bootstrap"
            },
            "port": {
              "type": "string"
            },
            "source": {
              "type": "string"
            },
            "target": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "source",
            "target",
            "port"
          ]
        },
        {
          "description": "The source and target exchange out-of-band data over a side-channel port.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "side_channel"
            },
            "port": {
              "type": "string"
            },
            "source": {
              "type": "string"
            },
            "target": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "source",
            "target",
            "port"
          ]
        }
      ]
    },
    "ServeRoleResult": {
      "description": "A role as the integration resolved it: preserved identity and cardinality\nwith the complete effective settings and parallelism.",
      "type": "object",
      "properties": {
        "effective_parallelism": {
          "$ref": "#/$defs/Parallelism"
        },
        "effective_settings": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/SettingValue"
          }
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ServeRoleKind"
        },
        "replica_count": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "replica_count",
        "effective_settings",
        "effective_parallelism"
      ]
    },
    "ServeTopology": {
      "description": "The serving deployment topology.",
      "oneOf": [
        {
          "description": "One aggregated serving role.",
          "type": "string",
          "const": "single"
        },
        {
          "description": "Disaggregated prefill and decode roles.",
          "type": "string",
          "const": "prefill_decode"
        }
      ]
    },
    "SettingValue": {
      "description": "A framework-specific server setting value carried as structured JSON data\n(never a pre-rendered shell fragment) across the integration boundary.",
      "anyOf": [
        {
          "description": "A JSON boolean.",
          "type": "boolean"
        },
        {
          "description": "A JSON integer.",
          "type": "integer",
          "format": "int64"
        },
        {
          "description": "A JSON floating-point number.",
          "type": "number",
          "format": "double"
        },
        {
          "description": "A JSON string.",
          "type": "string"
        },
        {
          "description": "A JSON array of setting values.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/SettingValue"
          }
        },
        {
          "description": "A JSON object of named setting values.",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/SettingValue"
          }
        }
      ]
    }
  }
}
