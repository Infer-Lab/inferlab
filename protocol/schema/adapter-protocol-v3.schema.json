      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ServeRoleKind"
        },
        "parallelism": {
          "$ref": "#/$defs/Parallelism"
        },
        "replica_count": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "settings": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/SettingValue"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "replica_count",
        "parallelism",
        "settings"
      ]
    },
