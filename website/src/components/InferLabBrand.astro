---
import inferlabMark from '../assets/inferlab-mark.svg';

interface Props {
  href: string;
  compact?: boolean;
}

const { href, compact = false } = Astro.props;
---

<a class:list={['inferlab-brand', { compact }]} href={href} aria-label="InferLab home">
  <img src={inferlabMark.src} alt="" width="40" height="40" />
  <span class="wordmark" aria-hidden="true">
    <span class="initial">I</span>nfer<span class="lab-initial">L</span>ab
  </span>
</a>

<style>
  .inferlab-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
  }

  img {
    width: 2.25rem;
    height: 2.25rem;
  }

  .wordmark {
    position: relative;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 1;
  }

  .initial,
  .lab-initial {
    position: relative;
  }

  .initial {
    margin-right: 0.005em;
  }

  .initial::before {
    position: absolute;
    top: -0.38em;
    left: 0.06em;
    width: 0.48em;
    height: 0.2em;
    background: var(--inferlab-blue);
    clip-path: polygon(0 0, 100% 0, 0 100%);
    content: "";
  }

  .lab-initial::after {
    position: absolute;
    bottom: 0.02em;
    left: 0.16em;
    width: 0.38em;
    height: 0.13em;
    background: var(--inferlab-blue);
    clip-path: polygon(0 100%, 100% 0, 100% 100%);
    content: "";
  }

  .compact {
    gap: 0.55rem;
  }

  .compact img {
    width: 2rem;
    height: 2rem;
  }

  .compact .wordmark {
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    img {
      width: 2rem;
      height: 2rem;
    }
  }
</style>
